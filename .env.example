# Soniq Environment Configuration
# This file is for docker-compose.yml - copy to .env

# ===========================================
# Database (Supabase)
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# LLM Configuration - Multi-provider fallback (Gemini -> OpenAI -> Groq)
# ===========================================
# Gemini (primary)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (fallback)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Groq (fallback)
GROQ_API_KEY=your-groq-api-key
GROQ_CHAT_MODEL=llama-3.1-8b-instant
GROQ_TOOL_MODEL=llama-3.3-70b-versatile

# Voice streaming provider order (comma-separated)
# Default: openai,groq,gemini
VOICE_LLM_PROVIDER_ORDER=openai,groq,gemini

# ===========================================
# Voice Stack
# ===========================================
DEEPGRAM_API_KEY=your-deepgram-api-key
CARTESIA_API_KEY=your-cartesia-api-key
SIGNALWIRE_PROJECT_ID=your-project-id
SIGNALWIRE_API_TOKEN=your-api-token
SIGNALWIRE_SPACE_URL=your-space.signalwire.com
SIGNALWIRE_WEBHOOK_SECRET=replace-with-long-random-secret
STREAM_SIGNING_SECRET=replace-with-long-random-secret
VAPI_WEBHOOK_SECRET=replace-with-long-random-secret
ENCRYPTION_KEY=replace-with-32-plus-char-secret

# ===========================================
# URLs
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:3100
NEXT_PUBLIC_TENANT_ID=your-tenant-id
BACKEND_URL=https://your-ngrok-url.ngrok-free.app

# ===========================================
# LiveKit (Voice Agent Pipeline)
# ===========================================
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Shared secret for LiveKit agent <-> API communication
INTERNAL_API_KEY=replace-with-long-random-secret
