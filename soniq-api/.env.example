# Soniq API Environment
# Copy to .env and fill in your values

# ===========================================
# Database (Supabase)
# ===========================================
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# LLM Configuration - Multi-provider fallback (Groq -> OpenAI -> Gemini)
# ===========================================
# Gemini (tertiary fallback) - https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (secondary fallback) - https://platform.openai.com
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini

# Groq (primary for low-latency voice) - https://console.groq.com
GROQ_API_KEY=your-groq-api-key
GROQ_CHAT_MODEL=openai/gpt-oss-20b
GROQ_TOOL_MODEL=openai/gpt-oss-20b

# Voice streaming provider order (comma-separated)
# Default: groq,openai,gemini
VOICE_LLM_PROVIDER_ORDER=groq,openai,gemini

# ===========================================
# Voice Stack (SignalWire + Deepgram + Cartesia)
# ===========================================
VOICE_PROVIDER=custom

# SignalWire (Telephony) - https://signalwire.com
SIGNALWIRE_PROJECT_ID=your-project-id
SIGNALWIRE_API_TOKEN=your-api-token
SIGNALWIRE_SPACE_URL=yourspace.signalwire.com
SIGNALWIRE_PHONE_NUMBER=+1xxxxxxxxxx
SIGNALWIRE_WEBHOOK_SECRET=replace-with-long-random-secret
STREAM_SIGNING_SECRET=replace-with-long-random-secret

# Deepgram (Speech-to-Text) - https://console.deepgram.com
DEEPGRAM_API_KEY=your-deepgram-key
DEEPGRAM_MODEL=nova-2-phonecall

# Cartesia (Text-to-Speech) - https://play.cartesia.ai
CARTESIA_API_KEY=your-cartesia-key

# ===========================================
# SMS (Twilio)
# ===========================================
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ===========================================
# Server
# ===========================================
PORT=3100
NODE_ENV=development
BACKEND_URL=https://your-ngrok-url.ngrok-free.app
FRONTEND_URL=http://localhost:3000
VAPI_WEBHOOK_SECRET=replace-with-long-random-secret
ENCRYPTION_KEY=replace-with-32-plus-char-secret

# ===========================================
# LiveKit Agent Communication
# ===========================================
# Shared secret for agent <-> API internal endpoints
INTERNAL_API_KEY=replace-with-long-random-secret
