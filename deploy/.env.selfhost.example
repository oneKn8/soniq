# Self-host env template for the Soniq auth+db tier on the Hetzner/Coolify box.
# Copy to deploy/.env.selfhost and fill in. Used by deploy/auth-postgres.compose.yml.
# NOTHING here is secret-by-default - generate real secrets before use.

# ── Postgres (dedicated Soniq database; separate from coolify-db/glitchtip-postgres) ──
POSTGRES_USER=soniq
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=soniq

# The API connects with this (raw pg Pool). Point at the dedicated Postgres above.
DATABASE_URL=postgres://soniq:replace-with-strong-password@db:5432/soniq

# ── Self-hosted auth (GoTrue = Supabase Auth) ──
# JWT secret used to SIGN and VERIFY user tokens. The SUPABASE_ANON_KEY and
# SUPABASE_SERVICE_ROLE_KEY the app uses MUST be JWTs signed with THIS secret
# (role=anon / role=service_role) or auth will not validate. Generate the keys
# with the Supabase JWT generator or a small script during the DB pass.
GOTRUE_JWT_SECRET=replace-with-32-plus-char-jwt-secret
SUPABASE_ANON_KEY=replace-with-anon-jwt-signed-by-GOTRUE_JWT_SECRET
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-jwt-signed-by-GOTRUE_JWT_SECRET

# Public base URL the dashboard/API point SUPABASE_URL at (Traefik routes /auth/v1 -> gotrue).
SUPABASE_URL=https://auth.soniq.ai
SITE_URL=https://app.soniq.ai

# Dev shortcut: skip email confirmation. Set false + configure SMTP for production.
GOTRUE_MAILER_AUTOCONFIRM=true
# SMTP (required when autoconfirm is false)
GOTRUE_SMTP_HOST=
GOTRUE_SMTP_PORT=587
GOTRUE_SMTP_USER=
GOTRUE_SMTP_PASS=
GOTRUE_SMTP_ADMIN_EMAIL=noreply@soniq.ai

# ── App secrets (mirror the service .env files) ──
ENCRYPTION_KEY=replace-with-32-plus-char-secret        # required in ALL envs (fail-closed crypto)
INTERNAL_API_KEY=replace-with-long-random-secret        # API <-> LiveKit agent
SIGNALWIRE_SIGNING_KEY=replace-with-signalwire-signing-key   # required in prod (webhook verification)

# ── Observability: point at the GlitchTip already running on this box ──
SENTRY_DSN=                # e.g. https://<key>@glitchtip.soniq.ai/<project>  (API)
NEXT_PUBLIC_SENTRY_DSN=    # client DSN for the dashboard
